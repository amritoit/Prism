<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Prism.ViewModels"
        xmlns:ctl="using:Prism.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1040" d:DesignHeight="680"
        x:Class="Prism.Views.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1040" Height="680"
        MinWidth="720" MinHeight="460"
        Background="{DynamicResource WindowBackground}"
        Title="Prism">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Buttons -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}"/>
        </Style>

        <Style Selector="Button.outline">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource OutlineForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource OutlineBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.outline:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource OutlineHoverBackground}"/>
        </Style>

        <!-- Chat bubbles -->
        <Style Selector="Border.bubble">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="13,10"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="MaxWidth" Value="640"/>
        </Style>
        <Style Selector="Border.user">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Background" Value="{DynamicResource BubbleUserBackground}"/>
        </Style>
        <Style Selector="Border.assistant">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Background" Value="{DynamicResource BubbleAssistantBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BubbleBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BoxShadow" Value="0 1 3 0 #1A000000"/>
        </Style>
        <Style Selector="Border.user SelectableTextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BubbleUserForeground}"/>
        </Style>
        <Style Selector="Border.assistant SelectableTextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BubbleAssistantForeground}"/>
        </Style>
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource HeaderForeground}"/>
            <Setter Property="Margin" Value="4,0,4,2"/>
        </Style>

        <!-- Sessions list -->
        <Style Selector="ListBox.sessions">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style Selector="ListBox.sessions ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource SessionItemForeground}"/>
        </Style>
        <Style Selector="ListBox.sessions ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SessionItemHoverBackground}"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="ListBox.sessions ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SessionItemSelectedBackground}"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <!-- Sidebar folder tree -->
        <Style Selector="TreeView.tree">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TreeView.tree TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="TreeView.tree TreeViewItem:selected /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource TreeSelectedBackground}"/>
        </Style>

        <!-- Compact icon button (sidebar) -->
        <Style Selector="Button.icon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource IconForeground}"/>
            <Setter Property="Padding" Value="7"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>
        <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource IconHoverBackground}"/>
        </Style>

        <!-- Per-row "…" menu: hidden until the row is hovered or selected -->
        <Style Selector="TreeView.tree Button.rowmenu">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="TreeView.tree TreeViewItem:pointerover Button.rowmenu">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="TreeView.tree TreeViewItem:selected Button.rowmenu">
            <Setter Property="Opacity" Value="1"/>
        </Style>
    </Window.Styles>

    <Grid>
        <!-- Main two-pane layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="170" MaxWidth="420"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="{DynamicResource SidebarGradientTopColor}" Offset="0"/>
                        <GradientStop Color="{DynamicResource SidebarGradientBottomColor}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="16,16,16,8" Spacing="10">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                            <Border Grid.Column="0" Width="14" Height="14" CornerRadius="4"
                                    VerticalAlignment="Center" Margin="0,0,8,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                        <GradientStop Color="#C0A587" Offset="0"/>
                                        <GradientStop Color="#9A7B58" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Prism" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TitleForeground}" VerticalAlignment="Center"/>

                            <Button Grid.Column="2" Classes="icon" Content="⌕"
                                    FontSize="18"
                                    ToolTip.Tip="Search chats"
                                    Command="{Binding ToggleSearchCommand}"/>
                            <Button Grid.Column="3" Classes="icon" Content="🗂"
                                    ToolTip.Tip="New folder"
                                    Command="{Binding ToggleNewFolderCommand}"/>
                        </Grid>

                        <TextBox Text="{Binding SearchText}"
                                 PlaceholderText="Search chats…"
                                 CornerRadius="8"
                                 IsVisible="{Binding IsSearchVisible}"/>

                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding IsNewFolderVisible}">
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewProjectName}"
                                     PlaceholderText="New folder name"
                                     CornerRadius="8"/>
                            <Button Grid.Column="1" Classes="primary" Content="+"
                                    Margin="6,0,0,0" Width="38"
                                    Command="{Binding AddProjectCommand}"/>
                        </Grid>
                    </StackPanel>

                    <!-- New chat pinned to the bottom of the sidebar -->
                    <Button DockPanel.Dock="Bottom"
                            Classes="primary" Content="+  New chat"
                            HorizontalAlignment="Stretch"
                            Margin="16,8,16,16"
                            Command="{Binding NewChatCommand}"/>

                    <TreeView Classes="tree"
                              ItemsSource="{Binding Groups}"
                              SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                              x:CompileBindings="False"
                              Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Margin="6,4,6,8">
                        <TreeView.DataTemplates>

                            <!-- Folder / group header -->
                            <TreeDataTemplate DataType="vm:SessionGroupViewModel"
                                              ItemsSource="{Binding Sessions}">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontWeight="Bold" FontSize="12"
                                               Foreground="{DynamicResource FolderForeground}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CountLabel}"
                                               FontSize="11" Foreground="{DynamicResource FolderCountForeground}"
                                               Margin="8,0,4,0"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Classes="icon rowmenu" Content="🗑"
                                            Padding="6,2" FontSize="13"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding CanDelete}"
                                            ToolTip.Tip="Delete folder"
                                            Command="{Binding $parent[TreeView].DataContext.DeleteProjectCommand}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </TreeDataTemplate>

                            <!-- Session row -->
                            <DataTemplate DataType="vm:SessionViewModel">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding Title}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource SessionTitleForeground}"/>
                                        <TextBlock Text="{Binding Subtitle}"
                                                   FontSize="11" Foreground="{DynamicResource SessionSubtitleForeground}"/>
                                    </StackPanel>

                                    <Button Grid.Column="1" Classes="icon rowmenu" Content="•••"
                                            Padding="8,2" FontSize="10"
                                            VerticalAlignment="Center"
                                            ToolTip.Tip="More">
                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuItem Header="Move to folder"
                                                          ItemsSource="{Binding MoveTargets}">
                                                    <MenuItem.ItemContainerTheme>
                                                        <ControlTheme TargetType="MenuItem"
                                                                      BasedOn="{StaticResource {x:Type MenuItem}}">
                                                            <Setter Property="Header" Value="{Binding Label}"/>
                                                            <Setter Property="Command" Value="{Binding Command}"/>
                                                        </ControlTheme>
                                                    </MenuItem.ItemContainerTheme>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="Delete chat"
                                                          Command="{Binding DeleteCommand}"/>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </TreeView.DataTemplates>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Draggable divider to resize the sidebar -->
            <GridSplitter Grid.Column="1" Width="5"
                          Background="{DynamicResource SplitterBackground}"
                          ResizeDirection="Columns"
                          HorizontalAlignment="Stretch"/>

            <!-- Main chat pane -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">

                <!-- Top toolbar -->
                <Border Grid.Row="0" Background="{DynamicResource PanelBarBackground}" BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="0,0,0,1" Padding="16,12">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                        <ComboBox Grid.Column="0"
                                  Width="160"
                                  ItemsSource="{Binding Providers}"
                                  SelectedItem="{Binding SelectedProvider}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <ComboBox Grid.Column="1"
                                  Width="168" Margin="8,0,0,0"
                                  ItemsSource="{Binding Models}"
                                  SelectedItem="{Binding SelectedModel}"/>

                        <TextBox Grid.Column="2" Margin="8,0,0,0" Width="150"
                                 Text="{Binding CustomModelText}"
                                 PlaceholderText="custom model id"
                                 IsVisible="{Binding IsCustomModel}"/>

                        <Button Grid.Column="4" Classes="outline" Content="⚙  Settings"
                                Command="{Binding ToggleSettingsCommand}"/>
                    </Grid>
                </Border>

                <!-- Decorative brain / neuron network behind the chat -->
                <Viewbox Grid.Row="1" Stretch="UniformToFill"
                         IsHitTestVisible="False" Opacity="0.14"
                         HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Canvas Width="780" Height="620" ClipToBounds="False">
                        <Canvas.Resources>
                            <SolidColorBrush x:Key="Synapse" Color="#6E5A40"/>
                            <SolidColorBrush x:Key="NodeGlow" Color="#D8C6AC"/>
                            <SolidColorBrush x:Key="NodeCore" Color="#8A6A47"/>
                        </Canvas.Resources>

                        <!-- Synapses (connections) -->
                        <Line StartPoint="120,90" EndPoint="300,60" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="300,60" EndPoint="470,120" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="470,120" EndPoint="650,80" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="120,90" EndPoint="200,240" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="300,60" EndPoint="400,220" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="470,120" EndPoint="400,220" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="650,80" EndPoint="600,260" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="200,240" EndPoint="400,220" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="400,220" EndPoint="600,260" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="200,240" EndPoint="120,400" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="400,220" EndPoint="330,420" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="600,260" EndPoint="520,400" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="120,400" EndPoint="330,420" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="330,420" EndPoint="520,400" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="520,400" EndPoint="700,440" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="600,260" EndPoint="700,440" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="120,400" EndPoint="250,540" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="330,420" EndPoint="470,540" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="520,400" EndPoint="470,540" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="700,440" EndPoint="640,560" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="250,540" EndPoint="470,540" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="470,540" EndPoint="640,560" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="400,220" EndPoint="520,400" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>
                        <Line StartPoint="330,420" EndPoint="250,540" Stroke="{StaticResource Synapse}" StrokeThickness="1.3"/>

                        <!-- Neuron nodes (glow + core) -->
                        <Ellipse Canvas.Left="102" Canvas.Top="72" Width="36" Height="36" Fill="{StaticResource NodeGlow}"/>
                        <Ellipse Canvas.Left="110" Canvas.Top="80" Width="20" Height="20" Fill="{StaticResource NodeCore}"/>
                        <Ellipse Canvas.Left="285" Canvas.Top="45" Width="30" Height="30" Fill="{StaticResource NodeGlow}"/>
                        <Ellipse Canvas.Left="293" Canvas.Top="53" Width="14" Height="14" Fill="{StaticResource NodeCore}"/>
                        <Ellipse Canvas.Left="453" Canvas.Top="103" Width="34" Height="34" Fill="{StaticResource NodeGlow}"/>
                        <Ellipse Canvas.Left="461" Canvas.Top="111" Width="18" Height="18" Fill="{StaticResource NodeCore}"/>
                        <Ellipse Canvas.Left="634" Canvas.Top="64" Width="32" Height="32" Fill="{StaticResource NodeGlow}"/>
                        <Ellipse Canvas.Left="642" Canvas.Top="72" Width="16" Height="16" Fill="{StaticResource NodeCore}"/>
                        <Ellipse Canvas.Left="184" Canvas.Top="224" Width="32" Height="32" Fill="{StaticResource NodeGlow}"/>
                        <Ellipse Canvas.Left="192" Canvas.Top="232" Width="16" Height="16" Fill="{StaticResource NodeCore}"/>
                        <Ellipse Canvas.Left="381" Canvas.Top="201" Width="38" Height="38" Fill="{StaticResource NodeGlow}"/>
                        <Ellipse Canvas.Left="389" Canvas.Top="209" Width="22" Height="22" Fill="{StaticResource NodeCore}"/>
                        <Ellipse Canvas.Left="585" Canvas.Top="245" Width="30" Height="30" Fill="{StaticResource NodeGlow}"/>
                        <Ellipse Canvas.Left="593" Canvas.Top="253" Width="14" Height="14" Fill="{StaticResource NodeCore}"/>
                        <Ellipse Canvas.Left="103" Canvas.Top="383" Width="34" Height="34" Fill="{StaticResource NodeGlow}"/>
                        <Ellipse Canvas.Left="111" Canvas.Top="391" Width="18" Height="18" Fill="{StaticResource NodeCore}"/>
                        <Ellipse Canvas.Left="314" Canvas.Top="404" Width="32" Height="32" Fill="{StaticResource NodeGlow}"/>
                        <Ellipse Canvas.Left="322" Canvas.Top="412" Width="16" Height="16" Fill="{StaticResource NodeCore}"/>
                        <Ellipse Canvas.Left="502" Canvas.Top="382" Width="36" Height="36" Fill="{StaticResource NodeGlow}"/>
                        <Ellipse Canvas.Left="510" Canvas.Top="390" Width="20" Height="20" Fill="{StaticResource NodeCore}"/>
                        <Ellipse Canvas.Left="684" Canvas.Top="424" Width="32" Height="32" Fill="{StaticResource NodeGlow}"/>
                        <Ellipse Canvas.Left="692" Canvas.Top="432" Width="16" Height="16" Fill="{StaticResource NodeCore}"/>
                        <Ellipse Canvas.Left="235" Canvas.Top="525" Width="30" Height="30" Fill="{StaticResource NodeGlow}"/>
                        <Ellipse Canvas.Left="243" Canvas.Top="533" Width="14" Height="14" Fill="{StaticResource NodeCore}"/>
                        <Ellipse Canvas.Left="453" Canvas.Top="523" Width="34" Height="34" Fill="{StaticResource NodeGlow}"/>
                        <Ellipse Canvas.Left="461" Canvas.Top="531" Width="18" Height="18" Fill="{StaticResource NodeCore}"/>
                        <Ellipse Canvas.Left="624" Canvas.Top="544" Width="32" Height="32" Fill="{StaticResource NodeGlow}"/>
                        <Ellipse Canvas.Left="632" Canvas.Top="552" Width="16" Height="16" Fill="{StaticResource NodeCore}"/>
                    </Canvas>
                </Viewbox>

                <!-- Chat area -->
                <ScrollViewer Grid.Row="1" Name="ChatScroll"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Messages}" Margin="20,14,20,20">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MessageViewModel">
                                <StackPanel>
                                    <TextBlock Classes="header" Text="{Binding Header}"/>
                                    <Border Classes="bubble"
                                            Classes.user="{Binding IsUser}"
                                            Classes.assistant="{Binding IsAssistant}">
                                        <StackPanel>
                                            <SelectableTextBlock ctl:Markdown.Text="{Binding Content}"
                                                                 TextWrapping="Wrap"
                                                                 IsVisible="{Binding Content, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <Image Source="{Binding Image}"
                                                   MaxWidth="420"
                                                   Margin="0,6,0,0"
                                                   HorizontalAlignment="Left"
                                                   IsVisible="{Binding HasImage}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Input bar -->
                <Border Grid.Row="2" Background="{DynamicResource PanelBarBackground}" BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="0,1,0,0" Padding="16,12">
                    <StackPanel Spacing="8">
                        <Border Background="{DynamicResource StatusBackground}" CornerRadius="8" Padding="10,7"
                                IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource StatusForeground}" TextWrapping="Wrap"/>
                        </Border>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Name="InputBox"
                                     Text="{Binding Input}"
                                     PlaceholderText="Type a message…  (Enter to send, Shift+Enter for newline)"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MaxHeight="150"
                                     CornerRadius="10"
                                     VerticalContentAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Bottom">
                                <Button Classes="primary" Content="Send"
                                        Command="{Binding SendCommand}"
                                        IsVisible="{Binding IsIdle}"/>
                                <Button Classes="danger" Content="Stop"
                                        Command="{Binding StopCommand}"
                                        IsVisible="{Binding IsBusy}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Settings overlay -->
        <Border Background="{DynamicResource OverlayBackground}"
                IsVisible="{Binding IsSettingsOpen}">
            <Border Background="{DynamicResource SettingsPanelBackground}" CornerRadius="16" Padding="22"
                    Width="540" MaxHeight="580"
                    BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1"
                    BoxShadow="0 10 40 0 #33000000"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Settings"
                               FontSize="19" FontWeight="Bold" Foreground="{DynamicResource SettingsHeadingForeground}"
                               Margin="0,0,0,14"/>

                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
                        <Button Classes="outline" Content="Cancel"
                                Command="{Binding ToggleSettingsCommand}"/>
                        <Button Classes="primary" Content="Save"
                                Command="{Binding SaveSettingsCommand}"/>
                    </StackPanel>

                    <ScrollViewer>
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="5">
                                <TextBlock Text="Appearance" FontWeight="SemiBold" Foreground="{DynamicResource SettingsLabelForeground}"/>
                                <ComboBox HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding ThemeOptions}"
                                          SelectedItem="{Binding SelectedTheme}"/>
                            </StackPanel>

                            <StackPanel Spacing="5">
                                <TextBlock Text="System prompt (optional)" FontWeight="SemiBold" Foreground="{DynamicResource SettingsLabelForeground}"/>
                                <TextBox Text="{Binding SystemPrompt}"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         MinHeight="60" CornerRadius="8"
                                         PlaceholderText="e.g. You are a helpful assistant."/>
                            </StackPanel>

                            <TextBlock Text="API keys" FontWeight="Bold" Foreground="{DynamicResource SettingsHeadingForeground}" Margin="0,4,0,0"/>
                            <ItemsControl ItemsSource="{Binding ProviderKeys}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ProviderKeyViewModel">
                                        <Border Background="{DynamicResource ProviderRowBackground}" CornerRadius="10"
                                                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1"
                                                Padding="12" Margin="0,0,0,10">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="SemiBold" Foreground="{DynamicResource ProviderNameForeground}"/>
                                                <TextBox Text="{Binding Key}"
                                                         PasswordChar="•" CornerRadius="8"
                                                         PlaceholderText="Paste API key"/>
                                                <Button Classes="outline"
                                                        Content="Sign in / get API key in browser"
                                                        HorizontalAlignment="Left"
                                                        Command="{Binding OpenPageCommand}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>
    </Grid>
</Window>
